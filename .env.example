# SmartFlow Environment Variables
# Copy this file to .env and fill in your values

# ── REQUIRED for AI wallet analysis ─────────────────────
# Free key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── REQUIRED for Telegram scraping ──────────────────────
# Get from: https://my.telegram.org → API Development Tools
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

# ── OPTIONAL (upgrade later) ────────────────────────────
# Birdeye free tier (500 req/day): https://birdeye.so/
BIRDEYE_API_KEY=

# ── DO NOT fill in — no key needed ──────────────────────
# 4chan:       No key needed (public JSON API)
# Reddit:      No key needed (public JSON)
# DEXScreener: No key needed (public API)
